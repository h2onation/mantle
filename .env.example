# mywalnut environment variables
#
# Copy this file to .env.local and fill in real values for the
# variables marked REQUIRED. Variables marked OPTIONAL only need
# to be set if you are using the corresponding feature.
#
# NEVER put secrets in NEXT_PUBLIC_ variables — anything with that
# prefix is shipped to the browser.

# ── Supabase (REQUIRED) ──────────────────────────────────────────
# Project URL and anon key are public; service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (REQUIRED) ─────────────────────────────────────────
# Powers Jove, the extraction layer, the classifier, and composition.
ANTHROPIC_API_KEY=sk-ant-...

# ── Linq SMS (REQUIRED for text channel) ─────────────────────────
# Inbound texts hit the webhook; outbound texts go through the API.
LINQ_API_TOKEN=your-linq-api-token
LINQ_PHONE_NUMBER=+15555550123
LINQ_WEBHOOK_SECRET=your-linq-webhook-secret
# Public-facing phone number shown in the UI (Settings → Text Jove).
NEXT_PUBLIC_LINQ_PHONE_NUMBER=+15555550123

# ── Upstash Redis (OPTIONAL — rate limiting) ─────────────────────
# If unset, all rate limiters fail open (no limiting). Set both to
# enable production rate limiting on /api/chat and OTP routes.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Deepgram (OPTIONAL — voice input) ────────────────────────────
# Required only if voice input is enabled in the UI.
DEEPGRAM_API_KEY=your-deepgram-key

# ── Dev only (OPTIONAL) ──────────────────────────────────────────
# Used by local "Simulate user" tooling. Never set in production.
DEV_USER_EMAIL=test@test.com
