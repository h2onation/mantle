# mywalnut environment variables
#
# Copy this file to .env.local and fill in real values for the
# variables marked REQUIRED. Variables marked OPTIONAL only need
# to be set if you are using the corresponding feature.
#
# NEVER put secrets in NEXT_PUBLIC_ variables — anything with that
# prefix is shipped to the browser.

# ── Supabase (REQUIRED) ──────────────────────────────────────────
# Project URL and anon key are public; service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (REQUIRED) ─────────────────────────────────────────
# Powers Jove, the extraction layer, the classifier, and composition.
ANTHROPIC_API_KEY=sk-ant-...

# ── Messaging providers (REQUIRED for text channel) ──────────────
# Dual-provider architecture:
#   - 1:1 text: Sendblue (default)
#   - Group facilitator: Linq (always — Sendblue has no participant events)
# Flip MESSAGING_PROVIDER=linq to revert 1:1 outbound to Linq. Inbound
# webhooks stay live on both endpoints. See ADR-035.

# Active 1:1 provider. Defaults to sendblue when unset.
MESSAGING_PROVIDER=sendblue

# Sendblue (1:1 provider). Credentials from the Sendblue dashboard.
SENDBLUE_API_KEY_ID=your-sendblue-key-id
SENDBLUE_API_SECRET_KEY=your-sendblue-secret
SENDBLUE_FROM_NUMBER=+15555550456
SENDBLUE_WEBHOOK_SECRET=your-sendblue-webhook-secret

# Linq (group facilitator + outbound rollback path).
LINQ_API_TOKEN=your-linq-api-token
LINQ_PHONE_NUMBER=+15555550123
LINQ_WEBHOOK_SECRET=your-linq-webhook-secret

# Public-facing phone number shown in the Settings UI.
NEXT_PUBLIC_MESSAGING_FROM_NUMBER=+15555550456
# Legacy — retained for rollback only. Do not reference in new code.
NEXT_PUBLIC_LINQ_PHONE_NUMBER=+15555550123

# ── Upstash Redis (OPTIONAL — rate limiting) ─────────────────────
# If unset, all rate limiters fail open (no limiting). Set both to
# enable production rate limiting on /api/chat and OTP routes.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Deepgram (OPTIONAL — voice input) ────────────────────────────
# Required only if voice input is enabled in the UI.
DEEPGRAM_API_KEY=your-deepgram-key

# ── Dev only (OPTIONAL) ──────────────────────────────────────────
# Used by local "Simulate user" tooling. Never set in production.
DEV_USER_EMAIL=test@test.com
